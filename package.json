{
  "name": "mp4-to-gif",
  "version": "1.0.0",
  "description": "Convert videos from files or URLs to GIF and more",
  "main": "electron-main.js",
  "scripts": {
    "start": "node server.js",
    "dev": "concurrently \"node server.js\" \"vite\"",
    "vite": "vite",
    "build": "vite build",
    "electron-dev": "electron .",
    "electron-build": "vite build && electron-builder"
  },
  "dependencies": {
    "express": "^4.18.2",
    "multer": "^1.4.5-lts.1",
    "solid-js": "^1.9.12",
    "uuid": "^9.0.0",
    "vite": "^8.0.3",
    "vite-plugin-solid": "^2.11.11"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "typescript": "^6.0.2"
  },
  "build": {
    "appId": "com.mp4togif.converter",
    "productName": "MP4 to GIF",
    "files": [
      "electron-main.js",
      "preload.js",
      "server.js",
      "public/**/*",
      "public-built/**/*",
      "node_modules/**/*"
    ],
    "mac": {
      "target": "dmg"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
