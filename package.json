{
  "name": "mp4-to-gif",
  "version": "1.0.0",
  "description": "High-quality MP4 to GIF converter",
  "main": "electron-main.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "electron-dev": "electron .",
    "electron-build": "electron-builder"
  },
  "dependencies": {
    "express": "^4.18.2",
    "multer": "^1.4.5-lts.1",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.mp4togif.converter",
    "productName": "MP4 to GIF",
    "files": [
      "electron-main.js",
      "server.js",
      "public/**/*",
      "node_modules/**/*"
    ],
    "mac": {
      "target": "dmg"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
