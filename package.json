{
  "name": "convertr",
  "version": "1.1.8",
  "description": "Convert videos from files or URLs to GIF, MP4, WebM, MOV, AVI, MKV, MP3",
  "main": "electron-main.js",
  "scripts": {
    "start": "node server.js",
    "dev": "concurrently \"node server.js\" \"vite\"",
    "vite": "vite",
    "build": "vite build",
    "electron-dev": "electron .",
    "electron-build": "vite build && electron-builder"
  },
  "dependencies": {
    "@ffprobe-installer/ffprobe": "^2.1.2",
    "express": "^4.18.2",
    "ffmpeg-static": "^5.3.0",
    "multer": "^1.4.5-lts.1",
    "solid-js": "^1.9.12",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vite-plugin-solid": "^2.11.11"
  },
  "build": {
    "appId": "com.convertr.app",
    "productName": "Convertr",
    "files": [
      "electron-main.js",
      "preload.js",
      "server.js",
      "server-utils.js",
      "server-config.js",
      "public-built/**/*"
    ],
    "asarUnpack": [
      "node_modules/ffmpeg-static/**/*",
      "node_modules/@ffprobe-installer/**/*"
    ],
    "publish": {
      "provider": "github",
      "owner": "Julioliolio",
      "repo": "convertr",
      "releaseType": "release"
    },
    "mac": {
      "artifactName": "${productName}-${version}-mac.${ext}",
      "target": "dmg",
      "icon": "static/icon.png",
      "category": "public.app-category.video"
    },
    "win": {
      "artifactName": "${productName}-${version}-windows.${ext}",
      "target": "nsis",
      "icon": "static/icon.png"
    },
    "linux": {
      "artifactName": "${productName}-${version}-linux.${ext}",
      "target": "AppImage",
      "icon": "static/icon.png"
    }
  }
}
